# Build glue for the UBController SimObject. To integrate:
#   ln -s /home/ubuntu/OpenURMA/eval/twonode/gem5_scaffold/src \
#         /home/ubuntu/gem5/src/dev/openurma
#   cd /home/ubuntu/gem5 && scons build/ARM/gem5.opt USE_SYSTEMC=1 -j$(nproc)
#
# The SConscript_link rule pulls in libopenurma_sc.a from OpenURMA's
# build/sc/ directory; OPENURMA_ROOT must be in the environment.

import os

Import('*')

SimObject('UBController.py', sim_objects=['UBController'])
Source('UBController.cc')

SimObject('NICTopologySC.py', sim_objects=['NICTopologySC'])
Source('NICTopologySC.cc')

SimObject('WireLoopback.py', sim_objects=['WireLoopback'])
Source('WireLoopback.cc')

SimObject('NICTopologyRoCE.py', sim_objects=['NICTopologyRoCE'])
Source('NICTopologyRoCE.cc')

# CqRegister was folded into NICTopologySC for the Phase H' Clean
# Architecture cut — a single Gem5ToTlmBridge512 covers the full
# uburma iomem range and NICTopologySC dispatches by offset (WR at
# 0..63, CQ at 64..127). Avoids a second SimObject + bridge for the
# CQE path and keeps the integration minimal.

DebugFlag('UBController')

OPENURMA_ROOT = os.environ.get('OPENURMA_ROOT', '/home/ubuntu/OpenURMA')
env.Append(CPPPATH=[
    os.path.join(OPENURMA_ROOT, 'runtime/openurma/include'),
    os.path.join(OPENURMA_ROOT, 'build/openurma_gen/systemc'),
    # OpenRoCE runtime headers (roce_meta, etc.) referenced by the
    # OpenRoCE topology_tlm.cpp NICTopologyRoCE.cc pulls in.
    os.path.join(OPENURMA_ROOT,
                 'baselines/openroce/runtime/openroce/include'),
    # OpenRoCE TLM topology is included by NICTopologyRoCE.cc via an
    # absolute path to avoid clashing with OpenURMA's same-named
    # topology_tlm.cpp; the file's namespace was renamed
    # (openurma::sc::tlm_topo → openroce::sc::tlm_topo) by
    # build_libsc_roce_tlm_gem5.sh so symbols don't collide at link.
    '/home/ubuntu/OpenClickNP/runtime/include',
])
env.Append(LIBS=['openurma_sc_tlm'])
# Use the gem5-ABI build (build/sc_gem5_tlm), NOT the system-SystemC
# build (build/sc_tlm). Linking the latter into gem5.opt fails with
# "undefined reference to sc_object::add_child_event" because gem5
# embeds its own SystemC with a different sc_object vtable layout.
env.Append(LIBPATH=[os.path.join(OPENURMA_ROOT, 'build/sc_gem5_tlm')])
